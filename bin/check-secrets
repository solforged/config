#!/usr/bin/env sh

set -eu

script_dir=$(
  CDPATH= cd -- "$(dirname -- "$0")" && pwd
)
repo_root=$(
  CDPATH= cd -- "$script_dir/.." && pwd
)

usage() {
  cat <<'EOF'
Usage: check-secrets [--staged]

Scans tracked files for likely plaintext secrets and blocks obvious secret-like
file types from entering git history.
EOF
}

mode="repo"
case "${1:-}" in
  "")
    ;;
  --staged)
    mode="staged"
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac

cd "$repo_root"

forbidden_name() {
  path="$1"

  case "$path" in
    *.age|*/.age-recipients|*/.age-recipients.example)
      return 1
      ;;
    *.env|*.env.*|*.key|*.p12|*.pem|*.pfx|*.pkcs12|*.tfstate|*.tfvars)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

skip_content_scan() {
  path="$1"

  case "$path" in
    *.age|*.example|*.example.*|*.md|*.sample|*.template|*.tmpl|*/.age-recipients|*/.age-recipients.example)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

content_pattern='BEGIN (EC|DSA|OPENSSH|PGP|PRIVATE|RSA) PRIVATE KEY|AGE-SECRET-KEY-1|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35}|aws_secret_access_key|gh[pousr]_[A-Za-z0-9_]{20,}|github_pat_[A-Za-z0-9_]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|authorization:[[:space:]]*(bearer|token)[[:space:]]+[A-Za-z0-9._-]{20,}'

paths_to_scan() {
  if [ "$mode" = "staged" ]; then
    git diff --cached --name-only --diff-filter=ACMR
  else
    git ls-files
  fi
}

status=0
paths_file="$(mktemp "${TMPDIR:-/tmp}/check-secrets-paths.XXXXXX")"

cleanup() {
  rm -f -- "$paths_file"
}

trap cleanup EXIT HUP INT TERM
paths_to_scan >"$paths_file"

while IFS= read -r path; do
  [ -n "$path" ] || continue

  if forbidden_name "$path"; then
    printf '%s\n' "forbidden secret-like path tracked in git: $path" >&2
    status=1
    continue
  fi

  if skip_content_scan "$path"; then
    continue
  fi

  if [ "$mode" = "repo" ] && [ ! -f "$path" ]; then
    continue
  fi

  tmp_output="$(mktemp "${TMPDIR:-/tmp}/check-secrets.XXXXXX")"

  if [ "$mode" = "staged" ]; then
    git show ":$path" | LC_ALL=C grep -E -n "$content_pattern" >"$tmp_output" 2>/dev/null || true
  else
    LC_ALL=C grep -E -n "$content_pattern" "$path" >"$tmp_output" 2>/dev/null || true
  fi

  if [ -s "$tmp_output" ]; then
    printf '%s\n' "possible plaintext secret content in $path" >&2
    sed 's/^/  /' "$tmp_output" >&2
    status=1
  fi

  rm -f -- "$tmp_output"
done <"$paths_file"

exit "$status"
