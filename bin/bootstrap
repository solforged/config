#!/usr/bin/env sh

# Bootstrap a fresh Mac from zero to fully configured.
#
# Usage:
#   curl -fsSL <raw-url>/bin/bootstrap | sh -s -- <host>
#   sh bin/bootstrap sigil

set -eu

die() {
  printf '%s\n' "error: $*" >&2
  exit 1
}

info() {
  printf '==> %s\n' "$*"
}

require_command() {
  command -v "$1" >/dev/null 2>&1
}

# ── Xcode CLT ────────────────────────────────────────────────────────

install_xcode_clt() {
  if xcode-select -p >/dev/null 2>&1; then
    info "Xcode CLT already installed"
    return 0
  fi

  info "installing Xcode Command Line Tools (required for git)"
  xcode-select --install 2>/dev/null || true

  # Wait for the installer to finish — it runs as a separate GUI process
  info "waiting for Xcode CLT installer to complete..."
  until xcode-select -p >/dev/null 2>&1; do
    sleep 5
  done
  info "Xcode CLT installed"
}

# ── Nix ──────────────────────────────────────────────────────────────

install_nix() {
  if require_command nix; then
    info "nix already installed"
    return 0
  fi

  info "installing Determinate Nix"
  curl --proto '=https' --tlsv1.2 -sSf -L \
    https://install.determinate.systems/nix | sh -s -- install

  # Source nix profile for the rest of this script
  if [ -f /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
    # shellcheck disable=SC1091
    . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
  fi

  require_command nix || die "nix installation failed"
}

# ── Clone config repo ────────────────────────────────────────────────

clone_config_repo() {
  repo_dir="${CONFIG_REPO_DIR:-${RIG_REPO_ROOT:-${PLATFORM_DIR:-$HOME/dev/personal/repos/config}}}"
  repo_url="${CONFIG_REPO_URL:-https://github.com/solforged/config.git}"

  if [ -d "$repo_dir/.git" ]; then
    info "config repo already present at $repo_dir"
    return 0
  fi

  info "cloning config repo to $repo_dir"
  mkdir -p "$(dirname "$repo_dir")"
  git clone "$repo_url" "$repo_dir"
}

# ── Main ─────────────────────────────────────────────────────────────

host="${1:-}"
[ -n "$host" ] || die "usage: bootstrap <host>"

install_xcode_clt
install_nix
clone_config_repo

repo_dir="${CONFIG_REPO_DIR:-${RIG_REPO_ROOT:-${PLATFORM_DIR:-$HOME/dev/personal/repos/config}}}"
info "running rig bootstrap $host"
exec "$repo_dir/bin/rig" bootstrap "$host"
