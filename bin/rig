#!/usr/bin/env sh

set -eu

resolve_script_path() {
  script_path="$1"

  case "$script_path" in
    */*)
      ;;
    *)
      script_path="$(command -v -- "$script_path" 2>/dev/null || true)"
      [ -n "$script_path" ] || die "could not resolve script path: $1"
      ;;
  esac

  while [ -L "$script_path" ]; do
    link_target="$(readlink "$script_path")" || die "could not read symlink: $script_path"

    case "$link_target" in
      /*)
        script_path="$link_target"
        ;;
      *)
        script_dir=$(
          CDPATH= cd -- "$(dirname -- "$script_path")" && pwd -P
        )
        script_path="$script_dir/$link_target"
        ;;
    esac
  done

  script_dir=$(
    CDPATH= cd -- "$(dirname -- "$script_path")" && pwd -P
  )
  printf '%s/%s\n' "$script_dir" "$(basename -- "$script_path")"
}

is_repo_root() {
  candidate="$1"
  [ -f "$candidate/flake.nix" ] && [ -f "$candidate/bin/rig" ] && [ -d "$candidate/hosts" ]
}

find_repo_root() {
  if [ -n "${RIG_REPO_ROOT:-}" ]; then
    if is_repo_root "$RIG_REPO_ROOT"; then
      printf '%s\n' "$RIG_REPO_ROOT"
      return 0
    fi
    die "RIG_REPO_ROOT is not a rig checkout: $RIG_REPO_ROOT"
  fi

  candidate=$(
    CDPATH= cd -- "$(dirname -- "$0")/.." 2>/dev/null && pwd -P
  ) || candidate=""
  if [ -n "$candidate" ] && is_repo_root "$candidate"; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate=$(
    CDPATH= cd -- "$(dirname -- "$(resolve_script_path "$0")")/.." 2>/dev/null && pwd -P
  ) || candidate=""
  if [ -n "$candidate" ] && is_repo_root "$candidate"; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="${XDG_DATA_HOME:-$HOME/.local/share}/platform"
  if is_repo_root "$candidate"; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="$PWD"
  while [ -n "$candidate" ] && [ "$candidate" != "/" ]; do
    if is_repo_root "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
    parent="$(dirname -- "$candidate")"
    [ "$parent" = "$candidate" ] && break
    candidate="$parent"
  done

  die "could not determine platform repo root; set RIG_REPO_ROOT"
}

if [ "${RIG_SOURCED_AS_LIB:-0}" != "1" ]; then
  repo_root="$(find_repo_root)"
fi

usage_main() {
  cat <<'EOF'
        _
       ( \
        \ \
         \ \
        / \ \
       / / \ \
      / /   \ \
     /_/     \_\

Usage: rig <command> [args]

Commands:
  bootstrap [host]         First-run decrypt, build, and activate for a host
  build [host]             Build the host system closure
  deploy [host] [--update] Build and activate the host
  check                    Run flake checks
  fmt                      Format the repository with the flake formatter
  update                   Update flake inputs
  host [host]              Print the detected default host
  hosts                    List known hosts
  secrets <subcommand>     Manage secrets via 1Password CLI
  install-hooks            Configure git to use the tracked pre-commit hook
  help [command]           Show help for rig or a command

Examples:
  rig build
  rig bootstrap sigil
  rig deploy
  rig deploy sigil --update
  rig fmt
  rig help deploy
  RIG_HOST=sigil rig deploy
  rig secrets pull
  rig secrets scan
EOF
}

usage_bootstrap() {
  cat <<'EOF'
Usage: rig bootstrap [host]

First-run activation flow for a host.

- Installs op CLI if not found
- Ensures 1Password is signed in
- Pulls secrets from 1Password via the manifest
- Builds and activates the target host

Environment:
  PLATFORM_SECRETS_DIR     Override the runtime secrets directory
  RIG_HOST                 Override auto-detected host slug

Examples:
  rig bootstrap
  rig bootstrap sigil
EOF
}

usage_deploy() {
  cat <<'EOF'
Usage: rig deploy [host] [--update]

Build and activate the target host.

Options:
  -u, --update             Run `nix flake update` before build and activation

Host resolution:
  - use the explicit host argument when provided
  - otherwise use RIG_HOST when set
  - otherwise auto-detect from the current machine name
  - otherwise fall back to the single known host when only one exists

Environment:
  PLATFORM_SECRETS_DIR     Override the runtime decrypt directory
  RIG_HOST                 Override auto-detected host slug

Examples:
  rig deploy
  rig deploy sigil
  rig deploy --update
  rig deploy sigil --update
  RIG_HOST=sigil rig deploy
EOF
}

usage_secrets() {
  cat <<'EOF'
Usage: rig secrets <subcommand> [args]

Secrets subcommands:
  pull [host]              Pull secrets from 1Password into XDG state
  scan                     Scan tracked files for likely plaintext secrets

Environment:
  PLATFORM_SECRETS_DIR     Override the runtime secrets directory
  RIG_HOST                 Override auto-detected host slug

Examples:
  rig secrets pull
  rig secrets pull sigil
  rig secrets scan
EOF
}

usage_help() {
  cat <<'EOF'
Usage: rig help [command]

Commands with dedicated help:
  bootstrap
  deploy
  secrets

Examples:
  rig help
  rig help deploy
  rig help bootstrap
  rig help secrets
EOF
}

die() {
  printf '%s\n' "error: $*" >&2
  exit 1
}

command_list() {
  cat <<'EOF'
bootstrap
build
deploy
check
fmt
update
host
hosts
secrets
install-hooks
help
EOF
}

secrets_command_list() {
  cat <<'EOF'
pull
scan
help
EOF
}

string_distance() {
  left="$1"
  right="$2"

  awk -v left="$left" -v right="$right" '
    function min3(a, b, c) {
      min = a
      if (b < min) {
        min = b
      }
      if (c < min) {
        min = c
      }
      return min
    }

    function distance(a, b,    i, j, la, lb, cost, deletion, insertion, substitution) {
      la = length(a)
      lb = length(b)

      for (j = 0; j <= lb; j++) {
        prev[j] = j
      }

      for (i = 1; i <= la; i++) {
        cur[0] = i
        for (j = 1; j <= lb; j++) {
          cost = (substr(a, i, 1) == substr(b, j, 1)) ? 0 : 1
          deletion = prev[j] + 1
          insertion = cur[j - 1] + 1
          substitution = prev[j - 1] + cost
          cur[j] = min3(deletion, insertion, substitution)
        }

        for (j = 0; j <= lb; j++) {
          prev[j] = cur[j]
        }
      }

      print prev[lb]
    }

    BEGIN {
      distance(left, right)
    }
  '
}

closest_match() {
  target="$1"

  awk -v target="$target" '
    function min3(a, b, c) {
      min = a
      if (b < min) {
        min = b
      }
      if (c < min) {
        min = c
      }
      return min
    }

    function distance(a, b,    i, j, la, lb, cost, deletion, insertion, substitution) {
      la = length(a)
      lb = length(b)

      for (j = 0; j <= lb; j++) {
        prev[j] = j
      }

      for (i = 1; i <= la; i++) {
        cur[0] = i
        for (j = 1; j <= lb; j++) {
          cost = (substr(a, i, 1) == substr(b, j, 1)) ? 0 : 1
          deletion = prev[j] + 1
          insertion = cur[j - 1] + 1
          substitution = prev[j - 1] + cost
          cur[j] = min3(deletion, insertion, substitution)
        }

        for (j = 0; j <= lb; j++) {
          prev[j] = cur[j]
        }
      }

      return prev[lb]
    }

    function shared_prefix(a, b,    i, max_len) {
      max_len = length(a)
      if (length(b) < max_len) {
        max_len = length(b)
      }

      for (i = 1; i <= max_len; i++) {
        if (substr(a, i, 1) != substr(b, i, 1)) {
          return i - 1
        }
      }

      return max_len
    }

    {
      candidate = $0
      score = distance(target, candidate)
      prefix = shared_prefix(target, candidate)

      if (best == "" || score < best_score || (score == best_score && prefix > best_prefix)) {
        best = candidate
        best_score = score
        best_prefix = prefix
      }
    }

    END {
      if (best != "") {
        print best
      }
    }
  '
}

removed_command_replacement() {
  cmd="$1"
  removed="$(printf '%s\n' switch update-switch | closest_match "$cmd")"
  distance="$(string_distance "$cmd" "$removed")"

  case "$removed" in
    switch)
      [ "$distance" -le 2 ] || return 1
      printf '%s\n' "deploy"
      ;;
    update-switch)
      [ "$distance" -le 4 ] || return 1
      printf '%s\n' "deploy --update"
      ;;
    *)
      return 1
      ;;
  esac
}

show_command_help() {
  topic="${1:-}"

  case "$topic" in
    "")
      usage_main
      ;;
    help)
      usage_help
      ;;
    bootstrap)
      usage_bootstrap
      ;;
    deploy)
      usage_deploy
      ;;
    secrets)
      usage_secrets
      ;;
    *)
      suggestion="$(command_list | closest_match "$topic")"
      printf '%s\n' "error: unknown help topic: $topic" >&2
      if [ -n "$suggestion" ]; then
        printf '%s\n' "hint: try 'rig help $suggestion'" >&2
      else
        printf '%s\n' "hint: try 'rig help'" >&2
      fi
      exit 1
      ;;
  esac
}

show_unknown_command() {
  cmd="$1"
  replacement="$(removed_command_replacement "$cmd" || true)"
  suggestion="$(command_list | closest_match "$cmd")"

  printf '%s\n' "error: unknown command: $cmd" >&2
  if [ -n "$replacement" ]; then
    printf '%s\n' "hint: use 'rig $replacement'" >&2
  elif [ -n "$suggestion" ]; then
    printf '%s\n' "hint: did you mean 'rig $suggestion'?" >&2
  fi
  printf '%s\n' "hint: run 'rig help' for usage" >&2
  exit 1
}

show_unknown_secrets_subcommand() {
  subcommand="$1"
  suggestion="$(secrets_command_list | closest_match "$subcommand")"

  printf '%s\n' "error: unknown secrets subcommand: $subcommand" >&2
  if [ -n "$suggestion" ]; then
    printf '%s\n' "hint: did you mean 'rig secrets $suggestion'?" >&2
  fi
  printf '%s\n' "hint: run 'rig help secrets' for usage" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

nix_cmd() {
  command nix --log-format raw "$@"
}

ensure_not_root() {
  if [ "$(id -u)" -eq 0 ]; then
    die "run rig as your normal user; it will invoke sudo only for activation"
  fi
}

list_hosts() {
  if [ -d "$repo_root/hosts/darwin" ]; then
    for path in "$repo_root"/hosts/darwin/*; do
      [ -f "$path/default.nix" ] || continue
      basename "$path"
    done
  fi

  if [ -d "$repo_root/hosts/nixos" ]; then
    for path in "$repo_root"/hosts/nixos/*; do
      [ -f "$path/default.nix" ] || continue
      basename "$path"
    done
  fi
}

single_host_if_any() {
  set -- $(list_hosts)
  if [ "$#" -eq 1 ]; then
    printf '%s\n' "$1"
  fi
}

detect_host() {
  if [ -n "${RIG_HOST:-}" ]; then
    printf '%s\n' "$RIG_HOST"
    return 0
  fi

  if command -v scutil >/dev/null 2>&1; then
    host_name="$(scutil --get LocalHostName 2>/dev/null || true)"
    if [ -n "$host_name" ] && host_exists "$host_name"; then
      printf '%s\n' "$host_name"
      return 0
    fi
  fi

  host_name="$(hostname -s 2>/dev/null || true)"
  if [ -n "$host_name" ] && host_exists "$host_name"; then
    printf '%s\n' "$host_name"
    return 0
  fi

  host_name="$(single_host_if_any || true)"
  if [ -n "$host_name" ]; then
    printf '%s\n' "$host_name"
    return 0
  fi

  die "could not determine a host; pass one explicitly or set RIG_HOST"
}

host_exists() {
  host="$1"
  [ -f "$repo_root/hosts/darwin/$host/default.nix" ] || [ -f "$repo_root/hosts/nixos/$host/default.nix" ]
}

host_kind() {
  host="$1"

  if [ -f "$repo_root/hosts/darwin/$host/default.nix" ]; then
    printf '%s\n' darwin
    return 0
  fi

  if [ -f "$repo_root/hosts/nixos/$host/default.nix" ]; then
    printf '%s\n' nixos
    return 0
  fi

  die "unknown host: $host"
}

host_profile_file() {
  host="$1"

  if [ -f "$repo_root/hosts/darwin/$host/preferences.nix" ]; then
    printf '%s\n' "$repo_root/hosts/darwin/$host/preferences.nix"
    return 0
  fi

  if [ -f "$repo_root/hosts/darwin/$host/default.nix" ]; then
    printf '%s\n' "$repo_root/hosts/darwin/$host/default.nix"
    return 0
  fi

  if [ -f "$repo_root/hosts/nixos/$host/preferences.nix" ]; then
    printf '%s\n' "$repo_root/hosts/nixos/$host/preferences.nix"
    return 0
  fi

  if [ -f "$repo_root/hosts/nixos/$host/default.nix" ]; then
    printf '%s\n' "$repo_root/hosts/nixos/$host/default.nix"
    return 0
  fi

  die "unknown host: $host"
}

host_has_profile() {
  host="$1"
  profile="$2"
  profile_file="$(host_profile_file "$host")"
  grep -q "${profile}\.enable[[:space:]]*=[[:space:]]*true" "$profile_file" ||
    grep -Eq "^[[:space:]]*\"$profile\"[[:space:]]*$" "$profile_file"
}

resolve_host_arg() {
  if [ "$#" -ge 1 ] && [ -n "$1" ]; then
    printf '%s\n' "$1"
  else
    detect_host
  fi
}

secret_state_dir() {
  printf '%s\n' "${PLATFORM_SECRETS_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/platform/secrets}"
}

require_op() {
  require_command op
}

install_op_cli() {
  if command -v op >/dev/null 2>&1; then
    return 0
  fi

  printf '%s\n' "installing 1Password CLI" >&2
  pkg_url="https://cache.agilebits.com/dist/1P/op2/pkg/v2.30.3/op_apple_universal_v2.30.3.pkg"
  tmp_pkg="$(mktemp "${TMPDIR:-/tmp}/op-cli.XXXXXX.pkg")"

  cleanup_op_pkg() {
    rm -f -- "$tmp_pkg"
  }
  trap cleanup_op_pkg EXIT HUP INT TERM

  curl -fsSL -o "$tmp_pkg" "$pkg_url"
  sudo installer -pkg "$tmp_pkg" -target /
  rm -f -- "$tmp_pkg"
  trap - EXIT HUP INT TERM

  command -v op >/dev/null 2>&1 || die "failed to install op CLI"
}

ensure_op_signed_in() {
  if op account list --format=json 2>/dev/null | grep -q '"url"'; then
    return 0
  fi

  printf '%s\n' "signing into 1Password (interactive)" >&2
  eval "$(op signin)"
}

secrets_manifest() {
  printf '%s\n' "$repo_root/secrets/manifest"
}

reset_secret_state_dir() {
  state_dir="$1"

  case "$state_dir" in
    */platform/secrets)
      ;;
    *)
      die "refusing to clear unexpected secret state dir: $state_dir"
      ;;
  esac

  rm -rf -- "$state_dir"
  mkdir -p "$state_dir"
  chmod 700 "$state_dir"
}

do_secrets_pull() {
  host="$(resolve_host_arg "$@")"
  state_dir="$(secret_state_dir)"
  manifest="$(secrets_manifest)"

  ensure_not_root
  require_op
  ensure_op_signed_in

  [ -f "$manifest" ] || die "no secrets/manifest found"

  reset_secret_state_dir "$state_dir"

  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ""|\#*)
        continue
        ;;
    esac

    scope="$(printf '%s\n' "$line" | awk '{ print $1 }')"
    local_path="$(printf '%s\n' "$line" | awk '{ print $2 }')"
    op_uri="$(printf '%s\n' "$line" | awk '{ print $3 }')"

    case "$scope" in
      shared)
        ;;
      work)
        host_has_profile "$host" work || continue
        ;;
      host:*)
        scope_host="${scope#host:}"
        [ "$scope_host" = "$host" ] || continue
        ;;
      *)
        printf '%s\n' "warning: unknown scope '$scope', skipping" >&2
        continue
        ;;
    esac

    target_path="$state_dir/$local_path"
    mkdir -p "$(dirname "$target_path")"
    op read "$op_uri" > "$target_path"
    chmod 600 "$target_path"
    printf '%s\n' "  $local_path"
  done < "$manifest"

  printf '%s\n' "pulled secrets to $state_dir"
}

maybe_pull_secrets() {
  host="$1"
  manifest="$(secrets_manifest)"

  if [ -f "$manifest" ]; then
    do_secrets_pull "$host"
  fi
}

do_secrets_scan() {
  ensure_not_root
  require_command git
  cd "$repo_root"
  exec "$repo_root/bin/check-secrets"
}

do_secrets() {
  subcommand="${1:-help}"
  if [ "$#" -gt 0 ]; then
    shift
  fi

  case "$subcommand" in
    pull)
      do_secrets_pull "$@"
      ;;
    scan)
      do_secrets_scan
      ;;
    help|-h|--help)
      usage_secrets
      ;;
    *)
      show_unknown_secrets_subcommand "$subcommand"
      ;;
  esac
}

do_install_hooks() {
  require_command git
  ensure_not_root
  cd "$repo_root"
  git config core.hooksPath hooks
  printf '%s\n' "configured git hooksPath to hooks"
}

build_host_closure() {
  host="$1"
  kind="$2"

  case "$kind" in
    darwin)
      nix_cmd build ".#darwinConfigurations.$host.system"
      ;;
    nixos)
      nix_cmd build ".#nixosConfigurations.$host.config.system.build.toplevel"
      ;;
    *)
      die "unsupported host kind: $kind"
      ;;
  esac
}

activate_built_host() {
  host="$1"
  kind="$2"

  case "$kind" in
    darwin)
      exec sudo ./result/sw/bin/darwin-rebuild switch --flake ".#$host"
      ;;
    nixos)
      exec sudo ./result/bin/switch-to-configuration switch
      ;;
    *)
      die "unsupported host kind: $kind"
      ;;
  esac
}

run_activation() {
  host="$1"
  kind="$2"
  update_inputs="${3:-0}"

  if [ "$update_inputs" -eq 1 ]; then
    nix_cmd flake update
  fi

  maybe_pull_secrets "$host"
  build_host_closure "$host" "$kind"
  activate_built_host "$host" "$kind"
}

parse_deploy_args() {
  deploy_host=""
  deploy_update=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -u|--update)
        deploy_update=1
        ;;
      -h|--help)
        usage_deploy
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        die "unknown deploy flag: $1"
        ;;
      *)
        if [ -n "$deploy_host" ]; then
          die "usage: rig deploy [host] [--update]"
        fi
        deploy_host="$1"
        ;;
    esac
    shift
  done

  while [ "$#" -gt 0 ]; do
    if [ -n "$deploy_host" ]; then
      die "usage: rig deploy [host] [--update]"
    fi
    deploy_host="$1"
    shift
  done

  if [ -n "$deploy_host" ]; then
    DEPLOY_HOST="$deploy_host"
  else
    DEPLOY_HOST="$(detect_host)"
  fi
  DEPLOY_UPDATE="$deploy_update"
}

do_bootstrap() {
  case "${1:-}" in
    -h|--help)
      usage_bootstrap
      exit 0
      ;;
  esac

  host="$(resolve_host_arg "$@")"
  kind="$(host_kind "$host")"

  require_command nix
  require_command sudo
  ensure_not_root
  install_op_cli

  cd "$repo_root"
  run_activation "$host" "$kind" 0
}

do_build() {
  host="$(resolve_host_arg "$@")"
  kind="$(host_kind "$host")"

  require_command nix
  ensure_not_root

  cd "$repo_root"
  build_host_closure "$host" "$kind"
}

do_deploy() {
  parse_deploy_args "$@"

  host="$DEPLOY_HOST"
  kind="$(host_kind "$host")"

  require_command nix
  require_command sudo
  ensure_not_root

  cd "$repo_root"
  run_activation "$host" "$kind" "$DEPLOY_UPDATE"
}

do_check() {
  require_command nix
  ensure_not_root
  cd "$repo_root"
  nix_cmd flake check
}

do_update() {
  require_command nix
  ensure_not_root
  cd "$repo_root"
  nix_cmd flake update
}

do_fmt() {
  require_command nix
  require_command git
  ensure_not_root
  cd "$repo_root"

  set --

  old_ifs=$IFS
  IFS='
'
  for path in $(git ls-files '*.nix'); do
    [ -f "$path" ] || continue
    set -- "$@" "$path"
  done
  IFS=$old_ifs

  if [ "$#" -eq 0 ]; then
    return 0
  fi

  nix_cmd fmt "$@"
}

if [ "${RIG_SOURCED_AS_LIB:-0}" != "1" ]; then

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$cmd" in
  bootstrap)
    do_bootstrap "$@"
    ;;
  build)
    do_build "$@"
    ;;
  deploy)
    do_deploy "$@"
    ;;
  check)
    do_check
    ;;
  fmt)
    do_fmt
    ;;
  update)
    do_update
    ;;
  host)
    resolve_host_arg "$@"
    ;;
  hosts)
    list_hosts
    ;;
  secrets)
    do_secrets "$@"
    ;;
  install-hooks)
    do_install_hooks
    ;;
  help|-h|--help)
    show_command_help "$@"
    ;;
  switch)
    die "'rig switch' was removed; use 'rig deploy'"
    ;;
  update-switch)
    die "'rig update-switch' was removed; use 'rig deploy --update'"
    ;;
  *)
    show_unknown_command "$cmd"
    ;;
esac

fi
