#!/usr/bin/env sh

set -eu

resolve_script_path() {
  script_path="$1"

  case "$script_path" in
    */*)
      ;;
    *)
      script_path="$(command -v -- "$script_path" 2>/dev/null || true)"
      [ -n "$script_path" ] || die "could not resolve script path: $1"
      ;;
  esac

  while [ -L "$script_path" ]; do
    link_target="$(readlink "$script_path")" || die "could not read symlink: $script_path"

    case "$link_target" in
      /*)
        script_path="$link_target"
        ;;
      *)
        script_dir=$(
          CDPATH= cd -- "$(dirname -- "$script_path")" && pwd -P
        )
        script_path="$script_dir/$link_target"
        ;;
    esac
  done

  script_dir=$(
    CDPATH= cd -- "$(dirname -- "$script_path")" && pwd -P
  )
  printf '%s/%s\n' "$script_dir" "$(basename -- "$script_path")"
}

is_repo_root() {
  candidate="$1"
  [ -f "$candidate/flake.nix" ] && [ -f "$candidate/bin/rig" ] && [ -d "$candidate/hosts" ]
}

find_repo_root() {
  if [ -n "${RIG_REPO_ROOT:-}" ]; then
    if is_repo_root "$RIG_REPO_ROOT"; then
      printf '%s\n' "$RIG_REPO_ROOT"
      return 0
    fi
    die "RIG_REPO_ROOT is not a rig checkout: $RIG_REPO_ROOT"
  fi

  candidate=$(
    CDPATH= cd -- "$(dirname -- "$0")/.." 2>/dev/null && pwd -P
  ) || candidate=""
  if [ -n "$candidate" ] && is_repo_root "$candidate"; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate=$(
    CDPATH= cd -- "$(dirname -- "$(resolve_script_path "$0")")/.." 2>/dev/null && pwd -P
  ) || candidate=""
  if [ -n "$candidate" ] && is_repo_root "$candidate"; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="${XDG_DATA_HOME:-$HOME/.local/share}/platform"
  if is_repo_root "$candidate"; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="$PWD"
  while [ -n "$candidate" ] && [ "$candidate" != "/" ]; do
    if is_repo_root "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
    parent="$(dirname -- "$candidate")"
    [ "$parent" = "$candidate" ] && break
    candidate="$parent"
  done

  die "could not determine platform repo root; set RIG_REPO_ROOT"
}

if [ "${RIG_SOURCED_AS_LIB:-0}" != "1" ]; then
  repo_root="$(find_repo_root)"
fi

usage_main() {
  cat <<'EOF'
        _
       ( \
        \ \
         \ \
        / \ \
       / / \ \
      / /   \ \
     /_/     \_\

Usage: rig <command> [args]

Commands:
  bootstrap [host]         One-shot setup: install deps, decrypt, build, activate
  build [host]             Build the host system closure
  deploy [host] [options]  Build and activate the host
  check                    Run flake checks
  context [host] [--json]  Show host config and repo state summary
  fmt                      Format the repository with the flake formatter
  update                   Update flake inputs
  hook [event]             Run or list lifecycle hooks
  host [host]              Print the detected default host
  hosts                    List known hosts
  secrets <subcommand>     Manage secrets via sops-nix
  swap [path]              Toggle config symlinks for mutable editing
  install-hooks            Configure git to use the tracked pre-commit hook
  help [command]           Show help for rig or a command

Examples:
  rig build
  rig bootstrap sigil
  rig deploy
  rig deploy sigil --update
  rig fmt
  rig help deploy
  RIG_HOST=sigil rig deploy
  rig secrets pull
  rig secrets scan
EOF
}

usage_bootstrap() {
  cat <<'EOF'
Usage: rig bootstrap [host]

First-run activation flow for a host.

- Installs Nix via the Determinate installer if not found
- Decrypts age key from secrets/age-key.age (passphrase prompt)
- Builds and activates the target host

Environment:
  PLATFORM_SECRETS_DIR     Override the runtime secrets directory
  RIG_HOST                 Override auto-detected host slug

Examples:
  rig bootstrap
  rig bootstrap sigil
EOF
}

usage_deploy() {
  cat <<'EOF'
Usage: rig deploy [host] [--update] [--verbose]

Build and activate the target host.
On first deploy for a machine, rig prompts for the SOPS age passphrase.

Options:
  -u, --update             Run `nix flake update` before build and activation
  -v, --verbose            Show full unfiltered output instead of spinner

Host resolution:
  - use the explicit host argument when provided
  - otherwise use RIG_HOST when set
  - otherwise auto-detect from the current machine name
  - otherwise fall back to the single known host when only one exists

Environment:
  PLATFORM_SECRETS_DIR     Override the runtime decrypt directory
  RIG_HOST                 Override auto-detected host slug

Examples:
  rig deploy
  rig deploy sigil
  rig deploy --update
  rig deploy sigil --update
  RIG_HOST=sigil rig deploy
EOF
}

usage_secrets() {
  cat <<'EOF'
Usage: rig secrets <subcommand> [args]

Secrets subcommands:
  pull                     Show info about sops-nix managed secrets
  scan                     Scan tracked files for likely plaintext secrets

File-based secrets are managed by sops-nix and decrypted at activation time.
To edit secrets: sops secrets/secrets.yaml

Examples:
  rig secrets pull
  rig secrets scan
EOF
}

usage_hook() {
  cat <<'EOF'
Usage: rig hook [event]

Run or list lifecycle hooks registered via platform.hooks.

Without arguments, lists available hook events.
With an event name, runs all hooks for that event.

Events:
  post-deploy              Runs after rig deploy completes

Hooks are declared in Nix via platform.hooks.postDeploy and
written to ~/.local/share/rig/hooks/ at activation time.

Examples:
  rig hook
  rig hook post-deploy
EOF
}

usage_swap() {
  cat <<'EOF'
Usage: rig swap [path] [--restore-all]

Toggle nix-store symlinks to mutable copies for rapid config iteration.
Lets you edit managed config files in-place without a full rebuild.

Without arguments, lists currently swapped files.
With a path, toggles that file between symlink and mutable copy.

Options:
  -R, --restore-all      Restore all swapped files to their original symlinks

rig deploy and rig build will refuse to run while files are swapped.

Examples:
  rig swap ~/.config/ghostty/config
  rig swap
  rig swap --restore-all
EOF
}

usage_context() {
  cat <<'EOF'
Usage: rig context [host] [--json]

Show a summary of the host configuration and repository state.
Useful as quick orientation for humans and AI coding agents.

Options:
  -j, --json               Output as JSON (requires jq)

Shows:
  - Host name and platform
  - Enabled profiles
  - Active app selections (shell, editor, terminal, browser)
  - Git state (branch, status, last commit)
  - Secrets status (age key present or missing)

Examples:
  rig context
  rig context sigil
  rig context --json
  rig context sigil --json
EOF
}

usage_help() {
  cat <<'EOF'
Usage: rig help [command]

Commands with dedicated help:
  bootstrap
  context
  deploy
  hook
  secrets
  swap

Examples:
  rig help
  rig help deploy
  rig help bootstrap
  rig help context
  rig help secrets
EOF
}

die() {
  printf '%s\n' "error: $*" >&2
  exit 1
}

command_list() {
  cat <<'EOF'
bootstrap
build
context
deploy
check
fmt
update
host
hosts
hook
secrets
swap
install-hooks
help
EOF
}

secrets_command_list() {
  cat <<'EOF'
pull
scan
help
EOF
}

string_distance() {
  left="$1"
  right="$2"

  awk -v left="$left" -v right="$right" '
    function min3(a, b, c) {
      min = a
      if (b < min) {
        min = b
      }
      if (c < min) {
        min = c
      }
      return min
    }

    function distance(a, b,    i, j, la, lb, cost, deletion, insertion, substitution) {
      la = length(a)
      lb = length(b)

      for (j = 0; j <= lb; j++) {
        prev[j] = j
      }

      for (i = 1; i <= la; i++) {
        cur[0] = i
        for (j = 1; j <= lb; j++) {
          cost = (substr(a, i, 1) == substr(b, j, 1)) ? 0 : 1
          deletion = prev[j] + 1
          insertion = cur[j - 1] + 1
          substitution = prev[j - 1] + cost
          cur[j] = min3(deletion, insertion, substitution)
        }

        for (j = 0; j <= lb; j++) {
          prev[j] = cur[j]
        }
      }

      print prev[lb]
    }

    BEGIN {
      distance(left, right)
    }
  '
}

closest_match() {
  target="$1"

  awk -v target="$target" '
    function min3(a, b, c) {
      min = a
      if (b < min) {
        min = b
      }
      if (c < min) {
        min = c
      }
      return min
    }

    function distance(a, b,    i, j, la, lb, cost, deletion, insertion, substitution) {
      la = length(a)
      lb = length(b)

      for (j = 0; j <= lb; j++) {
        prev[j] = j
      }

      for (i = 1; i <= la; i++) {
        cur[0] = i
        for (j = 1; j <= lb; j++) {
          cost = (substr(a, i, 1) == substr(b, j, 1)) ? 0 : 1
          deletion = prev[j] + 1
          insertion = cur[j - 1] + 1
          substitution = prev[j - 1] + cost
          cur[j] = min3(deletion, insertion, substitution)
        }

        for (j = 0; j <= lb; j++) {
          prev[j] = cur[j]
        }
      }

      return prev[lb]
    }

    function shared_prefix(a, b,    i, max_len) {
      max_len = length(a)
      if (length(b) < max_len) {
        max_len = length(b)
      }

      for (i = 1; i <= max_len; i++) {
        if (substr(a, i, 1) != substr(b, i, 1)) {
          return i - 1
        }
      }

      return max_len
    }

    {
      candidate = $0
      score = distance(target, candidate)
      prefix = shared_prefix(target, candidate)

      if (best == "" || score < best_score || (score == best_score && prefix > best_prefix)) {
        best = candidate
        best_score = score
        best_prefix = prefix
      }
    }

    END {
      if (best != "") {
        print best
      }
    }
  '
}

removed_command_replacement() {
  cmd="$1"
  removed="$(printf '%s\n' switch update-switch | closest_match "$cmd")"
  distance="$(string_distance "$cmd" "$removed")"

  case "$removed" in
    switch)
      [ "$distance" -le 2 ] || return 1
      printf '%s\n' "deploy"
      ;;
    update-switch)
      [ "$distance" -le 4 ] || return 1
      printf '%s\n' "deploy --update"
      ;;
    *)
      return 1
      ;;
  esac
}

show_command_help() {
  topic="${1:-}"

  case "$topic" in
    "")
      usage_main
      ;;
    help)
      usage_help
      ;;
    bootstrap)
      usage_bootstrap
      ;;
    context)
      usage_context
      ;;
    deploy)
      usage_deploy
      ;;
    hook)
      usage_hook
      ;;
    secrets)
      usage_secrets
      ;;
    swap)
      usage_swap
      ;;
    *)
      suggestion="$(command_list | closest_match "$topic")"
      printf '%s\n' "error: unknown help topic: $topic" >&2
      if [ -n "$suggestion" ]; then
        printf '%s\n' "hint: try 'rig help $suggestion'" >&2
      else
        printf '%s\n' "hint: try 'rig help'" >&2
      fi
      exit 1
      ;;
  esac
}

show_unknown_command() {
  cmd="$1"
  replacement="$(removed_command_replacement "$cmd" || true)"
  suggestion="$(command_list | closest_match "$cmd")"

  printf '%s\n' "error: unknown command: $cmd" >&2
  if [ -n "$replacement" ]; then
    printf '%s\n' "hint: use 'rig $replacement'" >&2
  elif [ -n "$suggestion" ]; then
    printf '%s\n' "hint: did you mean 'rig $suggestion'?" >&2
  fi
  printf '%s\n' "hint: run 'rig help' for usage" >&2
  exit 1
}

show_unknown_secrets_subcommand() {
  subcommand="$1"
  suggestion="$(secrets_command_list | closest_match "$subcommand")"

  printf '%s\n' "error: unknown secrets subcommand: $subcommand" >&2
  if [ -n "$suggestion" ]; then
    printf '%s\n' "hint: did you mean 'rig secrets $suggestion'?" >&2
  fi
  printf '%s\n' "hint: run 'rig help secrets' for usage" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

nix_cmd() {
  command nix --log-format raw "$@"
}

# ---------------------------------------------------------------------------
# Terminal UI helpers — spinner + phased output for deploy
# ---------------------------------------------------------------------------

RIG_VERBOSE="${RIG_VERBOSE:-0}"

_spinner_frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
_spinner_len=10

# ANSI color codes
_c_green='\033[32m'
_c_red='\033[31m'
_c_dim='\033[2m'
_c_reset='\033[0m'

is_interactive() {
  [ "$RIG_VERBOSE" -eq 0 ] && [ -t 2 ]
}

has_terminal() {
  [ -t 0 ] || [ -t 2 ] || [ -r /dev/tty ]
}

_cursor_hide() {
  printf '\033[?25l' >&2
}

_cursor_show() {
  printf '\033[?25h' >&2
}

_clear_line() {
  printf '\r\033[2K' >&2
}

_now_seconds() {
  date +%s
}

_format_duration() {
  total="$1"
  if [ "$total" -ge 60 ]; then
    mins=$((total / 60))
    secs=$((total % 60))
    printf '%dm%ds' "$mins" "$secs"
  else
    printf '%ds' "$total"
  fi
}

age_key_file() {
  printf '%s\n' "$HOME/.config/sops/age/keys.txt"
}

has_age_key() {
  [ -f "$(age_key_file)" ]
}

wait_for_enter() {
  if [ -r /dev/tty ]; then
    IFS= read -r _ </dev/tty
  else
    IFS= read -r _
  fi
}

prompt_age_key_bootstrap() {
  key_file="$(age_key_file)"

  if ! has_terminal; then
    die "missing SOPS age key at $key_file; rerun 'rig deploy' from an interactive terminal so rig can prompt for the passphrase"
  fi

  printf '\n' >&2
  printf '%s\n' "First deployment on this machine needs your SOPS age passphrase." >&2
  printf '%s\n' "rig will decrypt secrets/age-key.age into $key_file before continuing." >&2
  printf '%s\n' "Press Enter to continue, or Ctrl-C to cancel." >&2
  wait_for_enter
}

_print_success() {
  msg="$1"
  duration="$2"
  if [ -n "$duration" ] && [ "$duration" -gt 0 ]; then
    printf "${_c_green}✓${_c_reset} %s ${_c_dim}(%s)${_c_reset}\n" "$msg" "$(_format_duration "$duration")" >&2
  else
    printf "${_c_green}✓${_c_reset} %s\n" "$msg" >&2
  fi
}

_print_failure() {
  msg="$1"
  printf "${_c_red}✗${_c_reset} %s\n" "$msg" >&2
}

# Warnings to suppress in spinner mode (noisy / expected during development)
_is_suppressed_warning() {
  case "$1" in
    *"has uncommitted changes"*) return 0 ;;
  esac
  return 1
}

# run_phase "Building host" "Built host" command [args...]
#
# In interactive mode: shows a spinner while the command runs, updating with
# the last line of output. On success prints a checkmark; on failure dumps
# the full captured log.
#
# In non-interactive / verbose mode: runs the command with output passed through.
run_phase() {
  phase_label="$1"
  phase_done="$2"
  shift 2

  if ! is_interactive; then
    "$@"
    return $?
  fi

  phase_log="$(mktemp "${TMPDIR:-/tmp}/rig-phase.XXXXXX")"
  phase_start="$(_now_seconds)"

  # Ensure cleanup and cursor restore on any exit
  _phase_cleanup() {
    _cursor_show
    rm -f -- "$phase_log"
  }
  trap _phase_cleanup EXIT HUP INT TERM

  _cursor_hide

  # Run command in background, capturing all output
  "$@" >"$phase_log" 2>&1 &
  phase_pid=$!

  frame=0
  max_width="${COLUMNS:-80}"

  while kill -0 "$phase_pid" 2>/dev/null; do
    last="$(tail -1 "$phase_log" 2>/dev/null || true)"

    # Pick spinner frame
    idx=$((frame % _spinner_len))
    char=$(printf '%s' "$_spinner_frames" | cut -c "$((idx + 1))")

    # Build status line: spinner + label, with detail text dimmed
    if [ -n "$last" ]; then
      status_line="${char} ${phase_label}... $(printf "${_c_dim}")${last}$(printf "${_c_reset}")"
      # Plain version for length calculation (no ANSI escapes)
      plain_line="$char $phase_label... $last"
    else
      status_line="${char} ${phase_label}..."
      plain_line="$status_line"
    fi

    # Truncate to terminal width (based on visible character count)
    if [ "${#plain_line}" -gt "$max_width" ]; then
      # Rebuild truncated: cut the plain last-line portion
      avail=$((max_width - ${#phase_label} - 6))
      if [ "$avail" -gt 0 ] && [ -n "$last" ]; then
        truncated_last="$(printf '%s' "$last" | cut -c "1-$avail")"
        status_line="${char} ${phase_label}... $(printf "${_c_dim}")${truncated_last}$(printf "${_c_reset}")"
      else
        status_line="${char} ${phase_label}..."
      fi
    fi

    _clear_line
    printf '%s' "$status_line" >&2

    frame=$((frame + 1))
    sleep 0.1
  done

  # Collect exit status
  phase_status=0
  wait "$phase_pid" || phase_status=$?

  phase_end="$(_now_seconds)"
  phase_elapsed=$((phase_end - phase_start))

  _clear_line
  _cursor_show

  if [ "$phase_status" -eq 0 ]; then
    _print_success "$phase_done" "$phase_elapsed"
    # Surface any non-suppressed warnings that would otherwise be hidden
    if [ -s "$phase_log" ]; then
      grep -i '^warning:' "$phase_log" | while IFS= read -r wline; do
        _is_suppressed_warning "$wline" || printf "  ${_c_dim}%s${_c_reset}\n" "$wline" >&2
      done
    fi
  else
    _print_failure "$phase_label failed"
    # Dump full log so the user can see what went wrong
    if [ -s "$phase_log" ]; then
      cat "$phase_log" >&2
    fi
  fi

  rm -f -- "$phase_log"
  trap - EXIT HUP INT TERM

  return "$phase_status"
}

ensure_not_root() {
  if [ "$(id -u)" -eq 0 ]; then
    die "run rig as your normal user; it will invoke sudo only for activation"
  fi
}

list_hosts() {
  if [ -d "$repo_root/hosts/darwin" ]; then
    for path in "$repo_root"/hosts/darwin/*; do
      [ -f "$path/default.nix" ] || continue
      basename "$path"
    done
  fi

  if [ -d "$repo_root/hosts/nixos" ]; then
    for path in "$repo_root"/hosts/nixos/*; do
      [ -f "$path/default.nix" ] || continue
      basename "$path"
    done
  fi
}

single_host_if_any() {
  set -- $(list_hosts)
  if [ "$#" -eq 1 ]; then
    printf '%s\n' "$1"
  fi
}

detect_host() {
  if [ -n "${RIG_HOST:-}" ]; then
    printf '%s\n' "$RIG_HOST"
    return 0
  fi

  if command -v scutil >/dev/null 2>&1; then
    host_name="$(scutil --get LocalHostName 2>/dev/null || true)"
    if [ -n "$host_name" ] && host_exists "$host_name"; then
      printf '%s\n' "$host_name"
      return 0
    fi
  fi

  host_name="$(hostname -s 2>/dev/null || true)"
  if [ -n "$host_name" ] && host_exists "$host_name"; then
    printf '%s\n' "$host_name"
    return 0
  fi

  host_name="$(single_host_if_any || true)"
  if [ -n "$host_name" ]; then
    printf '%s\n' "$host_name"
    return 0
  fi

  die "could not determine a host; pass one explicitly or set RIG_HOST"
}

host_exists() {
  host="$1"
  [ -f "$repo_root/hosts/darwin/$host/default.nix" ] || [ -f "$repo_root/hosts/nixos/$host/default.nix" ]
}

host_kind() {
  host="$1"

  if [ -f "$repo_root/hosts/darwin/$host/default.nix" ]; then
    printf '%s\n' darwin
    return 0
  fi

  if [ -f "$repo_root/hosts/nixos/$host/default.nix" ]; then
    printf '%s\n' nixos
    return 0
  fi

  available="$(list_hosts | paste -sd', ' -)"
  die "unknown host: $host (available: $available)"
}

host_profile_file() {
  host="$1"

  if [ -f "$repo_root/hosts/darwin/$host/preferences.nix" ]; then
    printf '%s\n' "$repo_root/hosts/darwin/$host/preferences.nix"
    return 0
  fi

  if [ -f "$repo_root/hosts/darwin/$host/default.nix" ]; then
    printf '%s\n' "$repo_root/hosts/darwin/$host/default.nix"
    return 0
  fi

  if [ -f "$repo_root/hosts/nixos/$host/preferences.nix" ]; then
    printf '%s\n' "$repo_root/hosts/nixos/$host/preferences.nix"
    return 0
  fi

  if [ -f "$repo_root/hosts/nixos/$host/default.nix" ]; then
    printf '%s\n' "$repo_root/hosts/nixos/$host/default.nix"
    return 0
  fi

  die "unknown host: $host"
}

host_has_profile() {
  host="$1"
  profile="$2"
  profile_file="$(host_profile_file "$host")"
  grep -q "${profile}\.enable[[:space:]]*=[[:space:]]*true" "$profile_file" ||
    grep -Eq "^[[:space:]]*\"$profile\"[[:space:]]*$" "$profile_file"
}

host_has_feature() {
  host="$1"
  feature="$2"
  profile_file="$(host_profile_file "$host")"
  grep -q "${feature}\.enable[[:space:]]*=[[:space:]]*true" "$profile_file"
}

resolve_host_arg() {
  if [ "$#" -ge 1 ] && [ -n "$1" ]; then
    printf '%s\n' "$1"
  else
    detect_host
  fi
}

secret_state_dir() {
  printf '%s\n' "${PLATFORM_SECRETS_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/platform/secrets}"
}

require_op() {
  require_command op
}

install_nix() {
  if command -v nix >/dev/null 2>&1; then
    return 0
  fi

  printf '%s\n' "installing Nix (Determinate installer)" >&2
  curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix \
    | sh -s -- install --determinate

  # Source the Nix daemon environment so nix is available for the rest of bootstrap
  if [ -e /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
    . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
  fi

  command -v nix >/dev/null 2>&1 || die "failed to install Nix"
}

install_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    return 0
  fi

  printf '%s\n' "installing Homebrew" >&2
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # Homebrew on Apple Silicon installs to /opt/homebrew
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi

  command -v brew >/dev/null 2>&1 || die "failed to install Homebrew"
}

do_secrets_pull() {
  printf '%s\n' "info: file-based secrets are now managed by sops-nix and decrypted at activation time." >&2
  printf '%s\n' "hint: to edit secrets, run: sops secrets/secrets.yaml" >&2
}

maybe_pull_secrets() {
  # sops-nix handles file-based secrets at activation time.
  return 0
}

do_secrets_scan() {
  ensure_not_root
  require_command git
  cd "$repo_root"
  exec "$repo_root/bin/check-secrets"
}

do_secrets() {
  subcommand="${1:-help}"
  if [ "$#" -gt 0 ]; then
    shift
  fi

  case "$subcommand" in
    pull)
      do_secrets_pull "$@"
      ;;
    scan)
      do_secrets_scan
      ;;
    help|-h|--help)
      usage_secrets
      ;;
    *)
      show_unknown_secrets_subcommand "$subcommand"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Hooks — lifecycle event scripts
# ---------------------------------------------------------------------------

hook_dir() {
  printf '%s\n' "${XDG_DATA_HOME:-$HOME/.local/share}/rig/hooks"
}

run_hook() {
  event="$1"
  script="$(hook_dir)/$event"

  if [ ! -x "$script" ]; then
    return 0
  fi

  "$script"
}

do_hook() {
  case "${1:-}" in
    -h|--help)
      usage_hook
      exit 0
      ;;
    "")
      printf '%s\n' "Available hook events:"
      printf '  %s\n' "post-deploy"
      script="$(hook_dir)/post-deploy"
      if [ -x "$script" ]; then
        printf '\n%s\n' "post-deploy: installed"
      else
        printf '\n%s\n' "post-deploy: not configured"
      fi
      ;;
    post-deploy)
      script="$(hook_dir)/post-deploy"
      if [ ! -x "$script" ]; then
        printf '%s\n' "no post-deploy hook configured"
        exit 0
      fi
      run_hook post-deploy
      ;;
    *)
      die "unknown hook event: $1"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Swap — mutable config editing
# ---------------------------------------------------------------------------

swap_state_dir() {
  printf '%s\n' "${XDG_STATE_HOME:-$HOME/.local/state}/rig/swaps"
}

swap_manifest() {
  printf '%s\n' "$(swap_state_dir)/manifest"
}

has_active_swaps() {
  manifest="$(swap_manifest)"
  [ -s "$manifest" ]
}

require_no_active_swaps() {
  if has_active_swaps; then
    printf '%s\n' "error: cannot $1 while files are swapped:" >&2
    while IFS='	' read -r spath starget; do
      printf '  %s\n' "$spath" >&2
    done < "$(swap_manifest)"
    printf '%s\n' "hint: run 'rig swap --restore-all' first" >&2
    exit 1
  fi
}

resolve_absolute() {
  case "$1" in
    /*)
      printf '%s\n' "$1"
      ;;
    *)
      printf '%s\n' "$PWD/$1"
      ;;
  esac
}

swap_in() {
  path="$1"
  target="$(readlink "$path")" || die "could not read symlink: $path"
  manifest="$(swap_manifest)"

  mkdir -p "$(swap_state_dir)"
  cp -L "$path" "$path.rig-swap-tmp" || die "could not copy: $path"
  rm "$path"
  mv "$path.rig-swap-tmp" "$path"
  printf '%s\t%s\n' "$path" "$target" >> "$manifest"
  _print_success "swapped in $path (now mutable)" 0
}

swap_out() {
  path="$1"
  target="$2"
  manifest="$(swap_manifest)"

  if [ ! -e "$target" ]; then
    printf '%s\n' "warning: original target no longer exists: $target" >&2
    printf '%s\n' "hint: run 'rig deploy' after restoring to regenerate" >&2
  fi

  rm "$path" || die "could not remove mutable copy: $path"
  ln -s "$target" "$path" || die "could not restore symlink: $path -> $target"

  # Remove this entry from the manifest
  tmp="$(mktemp)"
  grep -v "^${path}	" "$manifest" > "$tmp" || true
  if [ -s "$tmp" ]; then
    mv "$tmp" "$manifest"
  else
    rm "$tmp" "$manifest"
    rmdir "$(swap_state_dir)" 2>/dev/null || true
  fi

  _print_success "restored $path" 0
}

do_swap() {
  case "${1:-}" in
    -h|--help)
      usage_swap
      exit 0
      ;;
    -R|--restore-all)
      manifest="$(swap_manifest)"
      if [ ! -s "$manifest" ]; then
        printf '%s\n' "no active swaps"
        exit 0
      fi
      # Read all entries first (modifying manifest during iteration)
      entries=""
      while IFS='	' read -r spath starget; do
        entries="${entries}${spath}	${starget}
"
      done < "$manifest"
      printf '%s' "$entries" | while IFS='	' read -r spath starget; do
        [ -n "$spath" ] || continue
        swap_out "$spath" "$starget"
      done
      ;;
    "")
      manifest="$(swap_manifest)"
      if [ ! -s "$manifest" ]; then
        printf '%s\n' "no active swaps"
        exit 0
      fi
      while IFS='	' read -r spath starget; do
        printf '%s -> %s\n' "$spath" "$starget"
      done < "$manifest"
      ;;
    -*)
      die "unknown swap flag: $1"
      ;;
    *)
      path="$(resolve_absolute "$1")"

      # Check if already swapped
      manifest="$(swap_manifest)"
      if [ -s "$manifest" ]; then
        existing_target="$(grep "^${path}	" "$manifest" | head -1 | cut -f2)"
        if [ -n "$existing_target" ]; then
          swap_out "$path" "$existing_target"
          exit 0
        fi
      fi

      # Must be a symlink to swap in
      if [ ! -L "$path" ]; then
        die "not a symlink: $path"
      fi

      swap_in "$path"
      ;;
  esac
}

do_install_hooks() {
  require_command git
  ensure_not_root
  cd "$repo_root"
  git config core.hooksPath hooks
  printf '%s\n' "configured git hooksPath to hooks"
}

build_host_closure() {
  host="$1"
  kind="$2"

  case "$kind" in
    darwin)
      nix_cmd build ".#darwinConfigurations.$host.system"
      ;;
    nixos)
      nix_cmd build ".#nixosConfigurations.$host.config.system.build.toplevel"
      ;;
    *)
      die "unsupported host kind: $kind"
      ;;
  esac
}

activate_built_host() {
  host="$1"
  kind="$2"

  case "$kind" in
    darwin)
      sudo ./result/sw/bin/darwin-rebuild switch --flake ".#$host"
      ;;
    nixos)
      sudo ./result/bin/switch-to-configuration switch
      ;;
    *)
      die "unsupported host kind: $kind"
      ;;
  esac
}

run_activation() {
  host="$1"
  kind="$2"
  update_inputs="${3:-0}"

  activation_start="$(_now_seconds)"

  # Pre-cache sudo credentials so the password prompt doesn't collide
  # with the spinner. In non-interactive mode this is a harmless no-op
  # if credentials are already cached.
  if is_interactive; then
    sudo -v
  fi

  # Determinate Nix installer may leave /etc/nix/nix.custom.conf which
  # nix-darwin refuses to overwrite. Move it aside before building.
  if [ "$kind" = "darwin" ] && [ -f /etc/nix/nix.custom.conf ]; then
    printf '%s\n' "moving /etc/nix/nix.custom.conf aside for nix-darwin" >&2
    sudo mv /etc/nix/nix.custom.conf /etc/nix/nix.custom.conf.before-nix-darwin
  fi

  if [ "$update_inputs" -eq 1 ]; then
    run_phase "Updating flake inputs" "Updated flake inputs" \
      nix_cmd flake update
  fi

  if [ "$kind" = "darwin" ] && ! has_age_key; then
    prompt_age_key_bootstrap
    ensure_age_key
    if has_terminal; then
      _print_success "SOPS age key ready" 0
    fi
  fi

  run_phase "Building $host" "Built $host" \
    build_host_closure "$host" "$kind"

  run_phase "Activating $host" "Activated $host" \
    activate_built_host "$host" "$kind"

  hook_script="$(hook_dir)/post-deploy"
  if [ -x "$hook_script" ]; then
    run_phase "Running post-deploy hooks" "Ran post-deploy hooks" \
      "$hook_script"
  fi

  if is_interactive; then
    activation_end="$(_now_seconds)"
    activation_elapsed=$((activation_end - activation_start))
    printf "\n${_c_green}✓${_c_reset} Deployed ${_c_green}%s${_c_reset} in %s\n" \
      "$host" "$(_format_duration "$activation_elapsed")" >&2
  fi
}

parse_deploy_args() {
  deploy_host=""
  deploy_update=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -u|--update)
        deploy_update=1
        ;;
      -v|--verbose)
        RIG_VERBOSE=1
        ;;
      -h|--help)
        usage_deploy
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        die "unknown deploy flag: $1"
        ;;
      *)
        if [ -n "$deploy_host" ]; then
          die "usage: rig deploy [host] [--update] [--verbose]"
        fi
        deploy_host="$1"
        ;;
    esac
    shift
  done

  while [ "$#" -gt 0 ]; do
    if [ -n "$deploy_host" ]; then
      die "usage: rig deploy [host] [--update] [--verbose]"
    fi
    deploy_host="$1"
    shift
  done

  if [ -n "$deploy_host" ]; then
    DEPLOY_HOST="$deploy_host"
  else
    DEPLOY_HOST="$(detect_host)"
  fi
  DEPLOY_UPDATE="$deploy_update"
}

ensure_identity() {
  identity_file="$repo_root/modules/local/identity.nix"
  [ -f "$identity_file" ] && return 0

  if ! has_terminal; then
    printf '%s\n' "warning: modules/local/identity.nix not found; git identity will not be configured" >&2
    return 0
  fi

  printf '\n' >&2
  printf '%s\n' "No local identity file found. This sets your git name and email." >&2
  printf '%s\n' "You can skip this and create modules/local/identity.nix later." >&2
  printf '\n' >&2

  printf '%s' "Full name (leave blank to skip): " >&2
  if [ -r /dev/tty ]; then
    IFS= read -r id_name </dev/tty
  else
    IFS= read -r id_name
  fi

  if [ -z "$id_name" ]; then
    printf '%s\n' "skipping identity setup" >&2
    return 0
  fi

  printf '%s' "Email: " >&2
  if [ -r /dev/tty ]; then
    IFS= read -r id_email </dev/tty
  else
    IFS= read -r id_email
  fi

  if [ -z "$id_email" ]; then
    printf '%s\n' "skipping identity setup" >&2
    return 0
  fi

  cat > "$identity_file" <<IDENTITY
{ ... }:
{
  platform.user = {
    fullName = "$id_name";
    email = "$id_email";
  };
}
IDENTITY
  printf '%s\n' "wrote $identity_file" >&2
}

ensure_age_key() {
  key_file="$(age_key_file)"
  [ -f "$key_file" ] && return 0

  encrypted="$repo_root/secrets/age-key.age"
  [ -f "$encrypted" ] || die "secrets/age-key.age not found; copy it from an existing machine or restore from backup"

  mkdir -p "$(dirname "$key_file")"
  if command -v age >/dev/null 2>&1; then
    age -d -o "$key_file" "$encrypted"
  else
    nix_cmd shell nixpkgs#age -c age -d -o "$key_file" "$encrypted"
  fi
  chmod 600 "$key_file"
}

nix_setting_value() {
  _nsv_key="$1"
  _nsv_file="$2"
  grep -E "${_nsv_key}[[:space:]]*=" "$_nsv_file" 2>/dev/null |
    grep -oE '"[^"]+"' |
    tr -d '"' |
    head -1
}

do_context() {
  json_mode=0
  context_host=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -j|--json)
        json_mode=1
        ;;
      -h|--help)
        usage_context
        exit 0
        ;;
      -*)
        die "unknown context flag: $1"
        ;;
      *)
        if [ -n "$context_host" ]; then
          die "usage: rig context [host] [--json]"
        fi
        context_host="$1"
        ;;
    esac
    shift
  done

  host="$(resolve_host_arg ${context_host:+"$context_host"})"
  kind="$(host_kind "$host")"
  profile_file="$(host_profile_file "$host")"

  # Enabled profiles
  known_profiles="base desktop development media personal work"
  enabled_profiles=""
  for p in $known_profiles; do
    if host_has_profile "$host" "$p" 2>/dev/null; then
      enabled_profiles="${enabled_profiles:+$enabled_profiles, }$p"
    fi
  done

  # App selections
  app_shell="$(nix_setting_value 'shell' "$profile_file")"
  app_editor="$(nix_setting_value 'editor' "$profile_file")"
  app_terminal="$(nix_setting_value 'terminal' "$profile_file")"
  app_browser="$(nix_setting_value 'browser' "$profile_file")"

  # Git state
  cd "$repo_root"
  git_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || printf 'detached')"
  git_commit="$(git log -1 --format='%h %s' 2>/dev/null || printf 'none')"
  git_dirty="$(git status --porcelain 2>/dev/null || true)"

  if [ -z "$git_dirty" ]; then
    git_status="clean"
  else
    modified="$(printf '%s\n' "$git_dirty" | grep -cE '^\s?[MADRCU]' || true)"
    untracked="$(printf '%s\n' "$git_dirty" | grep -c '^??' || true)"
    git_status="${modified} modified, ${untracked} untracked"
  fi

  # Secrets
  if has_age_key; then
    age_status="present"
  else
    age_status="missing"
  fi

  if [ "$json_mode" -eq 1 ]; then
    require_command jq

    profiles_json="[]"
    for p in $known_profiles; do
      if host_has_profile "$host" "$p" 2>/dev/null; then
        profiles_json="$(printf '%s' "$profiles_json" | jq -c --arg p "$p" '. + [$p]')"
      fi
    done

    jq -n \
      --arg host "$host" \
      --arg platform "$kind" \
      --argjson profiles "$profiles_json" \
      --arg shell "${app_shell:-}" \
      --arg editor "${app_editor:-}" \
      --arg terminal "${app_terminal:-}" \
      --arg browser "${app_browser:-}" \
      --arg repo_root "$repo_root" \
      --arg branch "$git_branch" \
      --arg status "$git_status" \
      --arg last_commit "$git_commit" \
      --argjson age_key "$([ "$age_status" = "present" ] && printf 'true' || printf 'false')" \
      '{
        host: { name: $host, platform: $platform },
        profiles: $profiles,
        apps: { shell: $shell, editor: $editor, terminal: $terminal, browser: $browser },
        repo: { root: $repo_root, branch: $branch, status: $status, last_commit: $last_commit },
        secrets: { age_key: $age_key }
      }'
  else
    printf '## Host\n'
    printf '%s (%s)\n\n' "$host" "$kind"

    printf '## Profiles\n'
    printf '%s\n\n' "${enabled_profiles:-none}"

    printf '## Apps\n'
    printf 'shell: %s | editor: %s | terminal: %s | browser: %s\n\n' \
      "${app_shell:--}" "${app_editor:--}" "${app_terminal:--}" "${app_browser:--}"

    printf '## Repository\n'
    printf 'root: %s\n' "$repo_root"
    printf 'branch: %s\n' "$git_branch"
    printf 'status: %s\n' "$git_status"
    printf 'last commit: %s\n\n' "$git_commit"

    printf '## Secrets\n'
    printf 'age key: %s\n' "$age_status"
  fi
}

do_bootstrap() {
  case "${1:-}" in
    -h|--help)
      usage_bootstrap
      exit 0
      ;;
  esac

  host="$(resolve_host_arg "$@")"
  kind="$(host_kind "$host")"

  require_command sudo
  ensure_not_root
  install_nix
  if [ "$kind" = "darwin" ] && host_has_feature "$host" homebrew; then
    install_homebrew
  fi

  ensure_identity

  cd "$repo_root"
  run_activation "$host" "$kind" 0
}

do_build() {
  host="$(resolve_host_arg "$@")"
  kind="$(host_kind "$host")"

  require_command nix
  ensure_not_root
  require_no_active_swaps "build"

  cd "$repo_root"
  build_host_closure "$host" "$kind"
}

do_deploy() {
  parse_deploy_args "$@"

  host="$DEPLOY_HOST"
  kind="$(host_kind "$host")"

  require_command nix
  require_command sudo
  ensure_not_root
  require_no_active_swaps "deploy"

  cd "$repo_root"
  run_activation "$host" "$kind" "$DEPLOY_UPDATE"
}

do_check() {
  require_command nix
  ensure_not_root
  cd "$repo_root"
  nix_cmd flake check
}

do_update() {
  require_command nix
  ensure_not_root
  cd "$repo_root"
  nix_cmd flake update
}

do_fmt() {
  require_command nix
  require_command git
  ensure_not_root
  cd "$repo_root"

  set --

  old_ifs=$IFS
  IFS='
'
  for path in $(git ls-files '*.nix'); do
    [ -f "$path" ] || continue
    set -- "$@" "$path"
  done
  IFS=$old_ifs

  if [ "$#" -eq 0 ]; then
    return 0
  fi

  nix_cmd fmt "$@"
}

if [ "${RIG_SOURCED_AS_LIB:-0}" != "1" ]; then

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$cmd" in
  bootstrap)
    do_bootstrap "$@"
    ;;
  build)
    do_build "$@"
    ;;
  deploy)
    do_deploy "$@"
    ;;
  check)
    do_check
    ;;
  context)
    do_context "$@"
    ;;
  fmt)
    do_fmt
    ;;
  update)
    do_update
    ;;
  hook)
    do_hook "$@"
    ;;
  host)
    resolve_host_arg "$@"
    ;;
  hosts)
    list_hosts
    ;;
  secrets)
    do_secrets "$@"
    ;;
  swap)
    do_swap "$@"
    ;;
  install-hooks)
    do_install_hooks
    ;;
  help|-h|--help)
    show_command_help "$@"
    ;;
  switch)
    die "'rig switch' was removed; use 'rig deploy'"
    ;;
  update-switch)
    die "'rig update-switch' was removed; use 'rig deploy --update'"
    ;;
  *)
    show_unknown_command "$cmd"
    ;;
esac

fi
